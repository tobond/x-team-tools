# Tiltignore file to optimize file watching performance
# Similar to .gitignore but for Tilt file watching

# Version control
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Build artifacts and dependencies
node_modules/
target/
build/
dist/
out/
*.class
*.jar
*.war
*.ear

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# Java
*.class
*.log
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
hs_err_pid*

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
.nyc_output

# Logs
*.log
logs/
log/

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Docker
.dockerignore

# Kubernetes
*.kubeconfig

# Tilt specific
.tilt-buildkit/

# Documentation that doesn't affect builds
README.md
CHANGELOG.md
LICENSE
*.md

# Configuration files that don't affect runtime
.editorconfig
.prettierrc
.eslintrc*
tsconfig.json
jest.config.js
webpack.config.js

# Test files (unless they affect the build)
*_test.go
*_test.py
*.test.js
*.spec.js
test/
tests/
__tests__/

# CI/CD files
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Jenkinsfile

# Package manager lock files (these can cause unnecessary rebuilds)
package-lock.json
yarn.lock
Pipfile.lock
go.sum

# Backup files
*.bak
*.backup
*.old

# Swap files
*.swp
*.swo

# Local development files
.local/
local/
dev/

# Database files
*.db
*.sqlite
*.sqlite3

# Certificate files
*.pem
*.key
*.crt
*.cert

# Archive files
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z