"""
Monitoring and validation resources for Tilt development environment
Provides comprehensive monitoring, validation, and debugging capabilities
"""

def setup_monitoring_resources(namespace, services_to_deploy):
    """Setup comprehensive monitoring and validation resources with enhanced debugging capabilities"""
    
    # Create real-time monitoring dashboard
    _create_monitoring_dashboard(namespace, services_to_deploy)
    
    # Setup service health monitoring
    _setup_service_health_monitoring(namespace, services_to_deploy)
    
    # Setup resource consumption monitoring
    _setup_resource_monitoring(namespace)
    
    # Setup validation resources
    _setup_validation_resources(namespace, services_to_deploy)

def _create_monitoring_dashboard(namespace, services_to_deploy):
    """Create comprehensive real-time monitoring dashboard"""
    
    local_resource(
        'monitoring-dashboard',
        labels=['monitoring'],
        cmd='''
        clear
        echo "🔍 TILT DEVELOPMENT ENVIRONMENT DASHBOARD"
        echo "========================================"
        echo "Namespace: ''' + namespace + '''"
        echo "Services: ''' + str(len(services_to_deploy) if services_to_deploy else 0) + '''"
        echo "Timestamp: $(date)"
        echo ""
        
        echo "📊 CLUSTER OVERVIEW"
        echo "-------------------"
        kubectl cluster-info --context $(kubectl config current-context) | head -2
        echo ""
        
        echo "🏗️  NAMESPACE RESOURCES"
        echo "----------------------"
        kubectl get all -n ''' + namespace + ''' --show-labels | head -20
        echo ""
        
        echo "📈 RESOURCE USAGE"
        echo "-----------------"
        kubectl top nodes 2>/dev/null | head -5 || echo "Node metrics unavailable"
        echo ""
        kubectl top pods -n ''' + namespace + ''' 2>/dev/null | head -10 || echo "Pod metrics unavailable"
        echo ""
        
        echo "🚨 RECENT EVENTS"
        echo "----------------"
        kubectl get events -n ''' + namespace + ''' --sort-by='.lastTimestamp' | tail -8
        echo ""
        
        echo "🔗 SERVICE ENDPOINTS"
        echo "-------------------"
        kubectl get svc -n ''' + namespace + ''' -o custom-columns="NAME:.metadata.name,TYPE:.spec.type,CLUSTER-IP:.spec.clusterIP,EXTERNAL-IP:.status.loadBalancer.ingress[0].ip,PORT(S):.spec.ports[*].port" 2>/dev/null || echo "No services found"
        echo ""
        
        echo "💡 Quick Actions:"
        echo "  • Click 'resource-monitor' for detailed metrics"
        echo "  • Click 'service-health-check' for health validation"
        echo "  • Click individual service monitors for specific details"
        echo "  • Tilt UI: http://localhost:10350"
        ''',
        deps=services_to_deploy if services_to_deploy else [],
        auto_init=True,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['dashboard', 'monitoring', 'overview']
    )

def _setup_service_health_monitoring(namespace, services_to_deploy):
    """Setup comprehensive service health monitoring"""
    
    if not services_to_deploy:
        return
    
    local_resource(
        'service-health-check',
        labels=['monitoring'],
        cmd='''
        echo "🏥 SERVICE HEALTH CHECK DASHBOARD"
        echo "================================="
        echo "Namespace: ''' + namespace + '''"
        echo "Checking ''' + str(len(services_to_deploy)) + ''' services..."
        echo ""
        
        OVERALL_STATUS="✅ HEALTHY"
        
        ''' + '\n        '.join([
            '''
        echo "🔍 Checking service: {service_name}..."
        POD_STATUS=$(kubectl get pods -n {namespace} -l app={service_name} -o jsonpath='{{.items[0].status.phase}}' 2>/dev/null || echo "NotFound")
        READY_STATUS=$(kubectl get pods -n {namespace} -l app={service_name} -o jsonpath='{{.items[0].status.conditions[?(@.type=="Ready")].status}}' 2>/dev/null || echo "Unknown")

        if [ "$POD_STATUS" = "Running" ] && [ "$READY_STATUS" = "True" ]; then
            echo "  ✅ {service_name}: Running and Ready"
        elif [ "$POD_STATUS" = "Running" ]; then
            echo "  ⚠️  {service_name}: Running but not Ready"
            OVERALL_STATUS="⚠️  DEGRADED"
        elif [ "$POD_STATUS" = "Pending" ]; then
            echo "  🔄 {service_name}: Starting up..."
            OVERALL_STATUS="🔄 STARTING"
        else
            echo "  ❌ {service_name}: $POD_STATUS"
            OVERALL_STATUS="❌ UNHEALTHY"
        fi
        
        # Show resource usage if available
        RESOURCE_USAGE=$(kubectl top pod -n {namespace} -l app={service_name} --no-headers 2>/dev/null | awk '{{print "CPU: " $2 ", Memory: " $3}}' || echo "Metrics unavailable")
        echo "     Resources: $RESOURCE_USAGE"
        
        # Show recent events
        RECENT_EVENTS=$(kubectl get events -n {namespace} --field-selector involvedObject.name={service_name} --sort-by='.lastTimestamp' --no-headers 2>/dev/null | tail -1 | awk '{{print $6 " " $7 " " $8 " " $9 " " $10}}' || echo "No recent events")
        if [ "$RECENT_EVENTS" != "No recent events" ]; then
            echo "     Latest: $RECENT_EVENTS"
        fi
        echo ""'''.format(service_name=service, namespace=namespace)
            for service in services_to_deploy
        ]) + '''
        
        echo "================================="
        echo "Overall Status: $OVERALL_STATUS"
        echo "================================="
        ''',
        deps=services_to_deploy,
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['health', 'monitoring', 'services']
    )

def _setup_resource_monitoring(namespace):
    """Setup enhanced resource consumption monitoring"""
    
    local_resource(
        'resource-monitor',
        labels=['monitoring'],
        cmd='''
        echo "📊 RESOURCE CONSUMPTION MONITOR"
        echo "==============================="
        echo "Namespace: ''' + namespace + '''"
        echo "Timestamp: $(date)"
        echo ""
        
        echo "🖥️  CLUSTER NODES"
        echo "----------------"
        kubectl top nodes 2>/dev/null || echo "❌ Node metrics unavailable (metrics-server may not be installed)"
        echo ""
        
        echo "📦 NAMESPACE PODS"
        echo "----------------"
        kubectl top pods -n ''' + namespace + ''' --sort-by=cpu 2>/dev/null || echo "❌ Pod metrics unavailable"
        echo ""
        
        echo "💾 STORAGE USAGE"
        echo "---------------"
        kubectl get pvc -n ''' + namespace + ''' -o custom-columns="NAME:.metadata.name,STATUS:.status.phase,VOLUME:.spec.volumeName,CAPACITY:.status.capacity.storage,USED:.status.capacity.storage" 2>/dev/null || echo "No persistent volumes"
        echo ""
        
        echo "🔒 RESOURCE QUOTAS"
        echo "------------------"
        kubectl describe resourcequota -n ''' + namespace + ''' 2>/dev/null || echo "No resource quotas configured"
        echo ""
        
        echo "⚠️  RESOURCE WARNINGS"
        echo "--------------------"
        # Check for high CPU usage (>80%)
        HIGH_CPU=$(kubectl top pods -n ''' + namespace + ''' --no-headers 2>/dev/null | awk '$2 ~ /[8-9][0-9]%|[0-9][0-9][0-9]%/ {print "🔥 " $1 ": " $2 " CPU"}' || echo "")
        if [ -n "$HIGH_CPU" ]; then
            echo "$HIGH_CPU"
        else
            echo "✅ No high CPU usage detected"
        fi
        
        # Check for high memory usage (>80%)
        HIGH_MEM=$(kubectl top pods -n ''' + namespace + ''' --no-headers 2>/dev/null | awk '$3 ~ /[8-9][0-9]%|[0-9][0-9][0-9]%/ {print "🔥 " $1 ": " $3 " Memory"}' || echo "")
        if [ -n "$HIGH_MEM" ]; then
            echo "$HIGH_MEM"
        else
            echo "✅ No high memory usage detected"
        fi
        
        echo ""
        echo "💡 Tip: Run this monitor regularly to track resource trends"
        ''',
        deps=[],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['monitoring', 'resources', 'performance']
    )

def _setup_validation_resources(namespace, services_to_deploy):
    """Setup comprehensive validation resources"""
    
    local_resource(
        'k8s-resource-validation',
        labels=['monitoring'],
        cmd='''
        echo "=== KUBERNETES RESOURCE VALIDATION ==="
        echo "Namespace: ''' + namespace + '''"
        echo ""
        
        echo "=== Deployments ==="
        kubectl get deployments -n ''' + namespace + ''' -o wide
        echo ""
        
        echo "=== Services ==="
        kubectl get services -n ''' + namespace + ''' -o wide
        echo ""
        
        echo "=== ConfigMaps ==="
        kubectl get configmaps -n ''' + namespace + ''' -o wide
        echo ""
        
        echo "=== Secrets ==="
        kubectl get secrets -n ''' + namespace + ''' -o wide
        echo ""
        
        echo "=== Pods Status ==="
        kubectl get pods -n ''' + namespace + ''' -o wide
        echo ""
        
        echo "=== Resource Events ==="
        kubectl get events -n ''' + namespace + ''' --sort-by='.lastTimestamp' | tail -10
        ''',
        deps=services_to_deploy if services_to_deploy else [],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['validation', 'k8s-resources']
    )
    
    # Manifest validation resource
    local_resource(
        'manifest-validation',
        labels=['monitoring'],
        cmd='''
        echo "=== KUBERNETES MANIFEST VALIDATION ==="
        
        # Validate all deployments have proper labels and annotations
        echo "Checking deployment labels and annotations..."
        kubectl get deployments -n ''' + namespace + ''' -o jsonpath='{range .items[*]}{.metadata.name}: labels={.metadata.labels}, annotations={.metadata.annotations}{"\n"}{end}' 2>/dev/null || echo "No deployments found"
        echo ""
        
        # Validate services have proper selectors
        echo "Checking service selectors..."
        kubectl get services -n ''' + namespace + ''' -o jsonpath='{range .items[*]}{.metadata.name}: selector={.spec.selector}{"\n"}{end}' 2>/dev/null || echo "No services found"
        echo ""
        
        # Check for proper resource limits
        echo "Checking resource limits..."
        kubectl get pods -n ''' + namespace + ''' -o jsonpath='{range .items[*]}{.metadata.name}: {range .spec.containers[*]}container={.name}, limits={.resources.limits}, requests={.resources.requests}{"\n"}{end}{end}' 2>/dev/null || echo "No pods found"
        echo ""
        
        # Validate health checks
        echo "Checking health probes..."
        kubectl get pods -n ''' + namespace + ''' -o jsonpath='{range .items[*]}{.metadata.name}: {range .spec.containers[*]}liveness={.livenessProbe.httpGet.path}, readiness={.readinessProbe.httpGet.path}{"\n"}{end}{end}' 2>/dev/null || echo "No pods found"
        ''',
        deps=services_to_deploy if services_to_deploy else [],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['validation', 'manifests']
    )

def setup_safety_monitoring():
    """Setup continuous safety monitoring"""
    
    local_resource(
        'safety-monitor',
        labels=['monitoring'],
        cmd='''
        echo "=== CONTINUOUS SAFETY MONITORING ==="
        CURRENT_CONTEXT=$(kubectl config current-context)
        echo "Current Context: $CURRENT_CONTEXT"
        
        # Check if context has changed to something dangerous
        case "$CURRENT_CONTEXT" in
            *prod*|*production*|*staging*|*stage*|*live*|*release*|*aws*|*gke*|*aks*|*eks*|*cloud*)
                echo "🚨 DANGER: Context appears to be non-local: $CURRENT_CONTEXT"
                echo "🛑 STOPPING OPERATIONS FOR SAFETY"
                exit 1
                ;;
            docker-desktop|docker-for-desktop|kind-*|k3d-*|minikube)
                echo "✅ Context is safe for local development"
                ;;
            *)
                echo "⚠️  WARNING: Unknown context pattern: $CURRENT_CONTEXT"
                echo "Proceeding with caution..."
                ;;
        esac
        
        echo "✅ Safety monitoring complete"
        ''',
        deps=[],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['safety', 'monitoring']
    )

def setup_debugging_resources(namespace, services_to_deploy):
    """Setup comprehensive debugging and troubleshooting resources"""
    
    local_resource(
        'debug-environment',
        labels=['support'],
        cmd='''
        echo "🐛 ENVIRONMENT DEBUGGING TOOLKIT"
        echo "================================"
        echo "Namespace: ''' + namespace + '''"
        echo ""
        
        echo "🔍 CLUSTER DIAGNOSTICS"
        echo "---------------------"
        echo "Context: $(kubectl config current-context)"
        echo "API Server: $(kubectl cluster-info | grep 'Kubernetes control plane' | awk '{print $NF}')"
        echo "Cluster Version: $(kubectl version --short --client 2>/dev/null | grep Client || echo 'Unknown')"
        echo ""
        
        echo "📊 NAMESPACE OVERVIEW"
        echo "--------------------"
        kubectl get all -n ''' + namespace + ''' --show-labels
        echo ""
        
        echo "🚨 FAILED RESOURCES"
        echo "------------------"
        echo "Failed Pods:"
        kubectl get pods -n ''' + namespace + ''' --field-selector=status.phase=Failed 2>/dev/null || echo "None"
        echo ""
        echo "Pending Pods:"
        kubectl get pods -n ''' + namespace + ''' --field-selector=status.phase=Pending 2>/dev/null || echo "None"
        echo ""
        
        echo "⚠️  WARNING EVENTS"
        echo "-----------------"
        kubectl get events -n ''' + namespace + ''' --field-selector type=Warning --sort-by='.lastTimestamp' | tail -10
        echo ""
        
        echo "🔧 QUICK FIXES"
        echo "-------------"
        echo "• Restart all services: tilt trigger <service-name>"
        echo "• View service logs: Click '<service-name>-monitor' in Tilt UI"
        echo "• Check resource usage: Click 'resource-monitor' in Tilt UI"
        echo "• Reset environment: Click 'cleanup-environment' then restart Tilt"
        ''',
        deps=services_to_deploy if services_to_deploy else [],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['debugging', 'troubleshooting', 'diagnostics']
    )
    
    local_resource(
        'logs-aggregator',
        labels=['monitoring'],
        cmd='''
        echo "📝 AGGREGATED LOGS VIEWER"
        echo "========================="
        echo "Namespace: ''' + namespace + '''"
        echo ""
        
        ''' + '\n        '.join([
            '''
        echo "=== LOGS: {} ==="
        POD_NAME=$(kubectl get pods -n {} -l app={} -o jsonpath='{{.items[0].metadata.name}}' 2>/dev/null)
        if [ -n "$POD_NAME" ]; then
            echo "Pod: $POD_NAME"
            kubectl logs $POD_NAME -n {} --tail=20 2>/dev/null || echo "❌ Logs unavailable"
        else
            echo "❌ No pod found for {}"
        fi
        echo ""'''.format(service, namespace, service, namespace, service) 
            for service in (services_to_deploy if services_to_deploy else [])
        ]) + '''
        
        echo "💡 For real-time logs, use: kubectl logs -f <pod-name> -n ''' + namespace + '''"
        ''',
        deps=services_to_deploy if services_to_deploy else [],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['logs', 'debugging', 'aggregation']
    )

def setup_service_dashboard(deployed_services, namespace):
    """Setup comprehensive service dashboard with real-time status"""
    
    if not deployed_services:
        return
    
    # Generate service status commands for each deployed service
    service_commands = []
    for svc in deployed_services:
        # Generate endpoint display logic for this specific service
        endpoint_lines = []
        for port in svc.get('ports', []):
            if svc.get('type') not in ['postgres', 'redis']:
                endpoint_lines.append('echo "   Endpoint: http://localhost:{}"'.format(port))

        endpoint_display = '\n        '.join(endpoint_lines) if endpoint_lines else ''

        service_cmd = '''
        echo "📦 SERVICE: {}"
        echo "   Type: {} | Build: {} | Ports: {}"
        
        # Get pod status
        POD_STATUS=$(kubectl get pods -n {} -l app={} -o jsonpath='{{.items[0].status.phase}}' 2>/dev/null || echo "NotFound")
        READY_STATUS=$(kubectl get pods -n {} -l app={} -o jsonpath='{{.items[0].status.conditions[?(@.type=="Ready")].status}}' 2>/dev/null || echo "Unknown")
        
        if [ "$POD_STATUS" = "Running" ] && [ "$READY_STATUS" = "True" ]; then
            echo "   Status: ✅ Running and Ready"
        elif [ "$POD_STATUS" = "Running" ]; then
            echo "   Status: ⚠️  Running but not Ready"
        elif [ "$POD_STATUS" = "Pending" ]; then
            echo "   Status: 🔄 Starting..."
        else
            echo "   Status: ❌ $POD_STATUS"
        fi
        
        # Show endpoints
        {}

        # Show resource usage
        RESOURCE_USAGE=$(kubectl top pod -n {} -l app={} --no-headers 2>/dev/null | awk '{{print $2 " CPU, " $3 " Memory"}}' || echo "Metrics unavailable")
        echo "   Resources: $RESOURCE_USAGE"
        echo ""'''.format(
            svc['name'],
            svc['type'],
            'Local' if svc['build_locally'] else 'ECR',
            ', '.join([str(p) for p in svc['ports']]) if svc['ports'] else 'None',
            namespace,
            svc['name'],
            namespace,
            svc['name'],
            endpoint_display,
            namespace,
            svc['name']
        )
        service_commands.append(service_cmd)

    local_resource(
        'service-dashboard',
        labels=['monitoring'],
        cmd='''
        clear
        echo "🎛️  SERVICE DASHBOARD"
        echo "===================="
        echo "Namespace: ''' + namespace + '''"
        echo "Services: ''' + str(len(deployed_services)) + '''"
        echo "Updated: $(date)"
        echo ""

        ''' + '\n        '.join(service_commands) + '''

        echo "🔗 QUICK ACTIONS"
        echo "==============="
        echo "• View individual service: Click '<service-name>-monitor'"
        echo "• Check endpoints: Click '<service-name>-endpoints'"
        echo "• View logs: Click 'logs-aggregator'"
        echo "• Debug issues: Click 'debug-environment'"
        echo "• Resource usage: Click 'resource-monitor'"
        ''',
        deps=[svc['name'] for svc in deployed_services],
        auto_init=True,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['dashboard', 'services', 'overview']
    )

def setup_cleanup_resources(namespace):
    """Setup environment cleanup resources"""
    
    local_resource(
        'cleanup-environment',
        labels=['support'],
        cmd='''
        echo "🧹 CLEANING UP DEVELOPMENT ENVIRONMENT"
        echo "======================================"
        echo "Namespace: ''' + namespace + '''"
        echo ""
        echo "⚠️  This will delete all resources in the namespace!"
        echo "Proceeding in 3 seconds... (Ctrl+C to cancel)"
        sleep 3
        echo ""
        echo "Deleting namespace..."
        kubectl delete namespace ''' + namespace + ''' --ignore-not-found=true
        echo "✅ Cleanup complete"
        echo ""
        echo "💡 Restart Tilt to recreate the environment"
        ''',
        deps=[],
        auto_init=False,
        trigger_mode=TRIGGER_MODE_MANUAL,
        labels=['cleanup', 'maintenance']
    )