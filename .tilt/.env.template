# Tilt Developer Configuration
# Copy this file to .tilt/.env and customize for your environment
# This file should NOT be committed to git

# Environment to deploy when running 'tilt up' without arguments
# Options: minimal, backend-only, full-stack, staging-mirror
TILT_ENVIRONMENT=backend-only

# Developer ID for namespace isolation (optional)
# Defaults to $USER if not set
# TILT_DEVELOPER_ID=yourname

# Enable debug output (optional)
# TILT_DEBUG=false

# Build images locally (optional)
# Set to false to use pre-built images from registry
# TILT_BUILD_LOCAL=true