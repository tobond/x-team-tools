{
  "feature": {
    "snapshots": true,
    "update_history": 10
  },
  "default_registry": "",
  "allowed_contexts": [
    "kind-tilt-dev",
    "k3d-tilt-dev", 
    "docker-desktop"
  ],
  "k8s_upsert_timeout_secs": 60,
  "default_to_tiltfile_args": [
    "--enable_debug=false"
  ],
  "team_settings": {
    "default_developer_namespace_prefix": "dev-",
    "default_cluster_type": "kind",
    "enable_resource_monitoring": true,
    "auto_cleanup_on_exit": false,
    "default_build_strategy": "ecr"
  },
  "extensions": {
    "namespace": {
      "enabled": true,
      "auto_create": true
    },
    "configmap": {
      "enabled": true
    },
    "secret": {
      "enabled": true
    },
    "helm_resource": {
      "enabled": false
    },
    "restart_process": {
      "enabled": true
    },
    "local_output": {
      "enabled": true
    }
  },
  "ui": {
    "web_mode": "prod",
    "web_port": 10350,
    "web_host": "localhost",
    "hud": true,
    "legacy_hud": false
  }
}