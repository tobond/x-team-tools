{
  "analytics": false,
  "feature": {
    "snapshots": true,
    "update_history": 10
  },
  "default_registry": "",
  "allowed_contexts": [
    "kind-tilt-dev",
    "k3d-tilt-dev", 
    "docker-desktop"
  ],
  "k8s_upsert_timeout_secs": 60,
  "default_to_tiltfile_args": [
    "--enable_debug=false"
  ],
  "team_settings": {
    "default_developer_namespace_prefix": "dev-",
    "default_cluster_type": "kind",
    "enable_resource_monitoring": true,
    "auto_cleanup_on_exit": false,
    "default_build_strategy": "ecr"
  },
  "extensions": {
    "namespace": {
      "enabled": true,
      "auto_create": true
    },
    "configmap": {
      "enabled": true
    },
    "secret": {
      "enabled": true
    },
    "helm_resource": {
      "enabled": false
    },
    "restart_process": {
      "enabled": true
    },
    "local_output": {
      "enabled": true
    }
  },
  "ui": {
    "web_mode": "prod",
    "web_port": 10350,
    "web_host": "localhost",
    "hud": true,
    "legacy_hud": false
  },
  "docker": {
    "prune": {
      "enabled": true,
      "max_age_mins": 360,
      "num_builds": 10,
      "interval_hrs": 1
    },
    "build": {
      "timeout_secs": 600,
      "cache_from": []
    }
  },
  "k8s": {
    "timeout_secs": 300,
    "namespace_creation_timeout_secs": 60,
    "pod_ready_timeout_secs": 300
  },
  "file_watch": {
    "enabled": true,
    "ignore_patterns": [
      "**/.git/**",
      "**/node_modules/**",
      "**/target/**",
      "**/__pycache__/**",
      "**/*.log",
      "**/tmp/**",
      "**/temp/**"
    ],
    "poll_interval_ms": 200
  },
  "update": {
    "mode": "auto",
    "batch_size": 1,
    "parallel_count": 4
  },
  "secrets": {
    "scrub_secrets": true,
    "env_vars_to_scrub": [
      "PASSWORD",
      "SECRET",
      "TOKEN",
      "KEY",
      "PRIVATE"
    ]
  },
  "logging": {
    "level": "info",
    "verbose": false,
    "json": false
  },
  "telemetry": {
    "enabled": false,
    "opt_in": false
  },
  "version_settings": {
    "check_updates": false
  },
  "experimental": {
    "analytics_nudge_surfaced": true
  }
}